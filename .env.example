# KAgent Environment Variables
# Copy this file to .env and fill in your actual values.
# .env is gitignored and will NOT be committed.

# API key for your LLM provider (shared across OpenAI / Anthropic / Gemini
# when using a unified proxy, or provider-specific key otherwise)
KAGENT_API_KEY=your-api-key-here

# Base URL override (optional — set this if you use a proxy or gateway)
# KAGENT_BASE_URL=https://api.openai.com/v1
